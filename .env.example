# LiteLLM Proxy Configuration
LITELLM_BASE_URL=http://localhost:6655/litellm/v1
LITELLM_API_KEY=API_KEY
# Available: anthropic--claude-4.6-sonnet, anthropic--claude-4.6-opus, anthropic--claude-4.5-opus
LITELLM_MODEL=anthropic--claude-4.6-sonnet

# Strava API Configuration (fill in after creating a Strava API app)
# https://www.strava.com/settings/api
STRAVA_CLIENT_ID=CLIENT_ID
STRAVA_CLIENT_SECRET=CLIENT_SECRET
STRAVA_ACCESS_TOKEN=ACCESS_TOKEN
STRAVA_REFRESH_TOKEN=REFRESH_TOKEN
STRAVA_TOKEN_EXPIRES_AT=0