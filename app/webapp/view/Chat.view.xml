<mvc:View
    controllerName="com.coach.agent.controller.Chat"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:mvc="sap.ui.core.mvc">

    <Page class="coachPage" showHeader="false" enableScrolling="false">
        <content>
            <f:Card
                height="100%"
                class="coachCard sapUiTinyMarginTopBottom">
                <f:content>
                    <VBox
                        width="100%"
                        height="100%"
                        fitContainer="true"
                        class="coachVBox">

                        <!-- Header toolbar -->
                        <Toolbar height="4rem">
                            <core:Icon size="1.6rem" src="sap-icon://stethoscope" class="sapUiSmallMarginBegin"/>
                            <Title
                                text="{i18n>appTitle}"
                                titleStyle="H5"
                                class="sapUiSmallMarginBegin"/>
                            <ToolbarSpacer/>
                            <ObjectStatus
                                text="{chat>/agentStatus}"
                                state="{= ${chat>/agentStatus} === 'Online' ? 'Success' : 'Error' }"
                                icon="sap-icon://status-positive"/>
                            <Button
                                icon="sap-icon://create-session"
                                type="Transparent"
                                tooltip="{i18n>btnNewThread}"
                                press=".onNewThread"/>
                            <Button
                                icon="sap-icon://refresh"
                                type="Transparent"
                                tooltip="{i18n>btnLoadAgentCard}"
                                press=".onLoadAgentCard"/>
                        </Toolbar>

                        <!-- Medical disclaimer banner (always visible) -->
                        <HBox justifyContent="Center" class="sapUiTinyMarginTop medicalWarning">
                            <VBox width="98%">
                                <MessageStrip
                                    text="{i18n>medicalWarning}"
                                    type="Warning"
                                    showIcon="true"
                                    showCloseButton="false"/>
                            </VBox>
                        </HBox>

                        <!-- Chat message list -->
                        <VBox
                            id="chatArea"
                            width="100%"
                            class="coachScroll">
                            <layoutData>
                                <FlexItemData growFactor="1"/>
                            </layoutData>
                            <List
                                id="messageList"
                                showSeparators="None"
                                showNoData="true"
                                noDataText="{i18n>noMessages}"
                                items="{chat>/messages}">
                                <CustomListItem type="Inactive">
                                    <!-- Agent message (left-aligned with icon) -->
                                    <HBox
                                        visible="{= ${chat>role} === 'agent' }"
                                        class="chat-item-ai sapUiTinyMarginBegin sapUiLargeMarginEnd sapUiSmallMarginTopBottom"
                                        alignItems="Start">
                                        <core:Icon
                                            src="sap-icon://stethoscope"
                                            size="1rem"
                                            class="sapUiSmallMarginBegin sapUiSmallMarginTop"
                                            color="#4db8ff"/>
                                        <VBox
                                            class="sapUiSmallMarginBegin sapUiSmallMarginTopBottom sapUiSmallMarginEnd"
                                            width="100%">
                                            <FormattedText
                                                htmlText="{chat>contentHtml}"
                                                class="sapUiTinyMarginBegin"/>
                                            <Button
                                                text="🗺 Find nearby doctors"
                                                type="Transparent"
                                                visible="{chat>hasMedicalContent}"
                                                press=".onFindDoctors"
                                                class="findDoctorsBtn sapUiTinyMarginTop"/>
                                        </VBox>
                                    </HBox>

                                    <!-- User message (right-aligned with icon) -->
                                    <HBox
                                        visible="{= ${chat>role} === 'user' }"
                                        class="chat-item-user sapUiTinyMarginEnd sapUiLargeMarginBegin sapUiSmallMarginTopBottom"
                                        alignItems="Center"
                                        justifyContent="End">
                                        <VBox class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTopBottom">
                                            <Text text="{chat>content}" textAlign="End"/>
                                        </VBox>
                                        <core:Icon
                                            src="sap-icon://person-placeholder"
                                            size="1rem"
                                            class="sapUiSmallMarginEnd"
                                            color="#90caf9"/>
                                    </HBox>
                                </CustomListItem>
                            </List>
                        </VBox>

                        <!-- Working indicator -->
                        <MessageStrip
                            id="statusStrip"
                            text="{chat>/statusMessage}"
                            type="Information"
                            showIcon="true"
                            visible="{= !!${chat>/isLoading} }"/>

                        <!-- Hidden file input for PDF upload -->
                        <core:HTML id="pdfFileInput" content="&lt;input type='file' id='pdfUploadInput' accept='.pdf' style='display:none'/&gt;"/>

                        <!-- Input area -->
                        <HBox
                            justifyContent="Center"
                            class="sapUiTinyMargin"
                            id="inputContainer">
                            <VBox width="90%" id="inputBox">
                                <TextArea
                                    id="userInput"
                                    placeholder="{i18n>inputPlaceholder}"
                                    growing="true"
                                    growingMaxLines="5"
                                    class="cInput"
                                    enabled="{= !${chat>/isLoading} }">
                                    <layoutData>
                                        <FlexItemData growFactor="1" maxWidth="100%"/>
                                    </layoutData>
                                </TextArea>
                            </VBox>
                            <Button
                                id="pdfButton"
                                class="pdfButton"
                                icon="sap-icon://pdf-attachment"
                                type="Transparent"
                                tooltip="{i18n>btnUploadPdf}"
                                press=".onUploadPdf"
                                enabled="{= !${chat>/isLoading} }"/>
                            <Button
                                id="clearButton"
                                class="cButton"
                                icon="sap-icon://decline"
                                type="Transparent"
                                press=".onClearInput"/>
                            <Button
                                id="sendBtn"
                                class="sButton"
                                icon="sap-icon://paper-plane"
                                type="Transparent"
                                press=".onSend"
                                enabled="{= !${chat>/isLoading} }"/>
                        </HBox>

                        <!-- Disclaimer -->
                        <HBox justifyContent="Center">
                            <VBox width="89%" alignContent="Start">
                                <MessageStrip
                                    text="{i18n>chatDisclaimer}"
                                    enableFormattedText="true"
                                    showIcon="true"
                                    showCloseButton="true"
                                    class="sapUiMediumMarginBottom"
                                    type="Information"/>
                            </VBox>
                        </HBox>

                    </VBox>
                </f:content>
            </f:Card>
        </content>
    </Page>

</mvc:View>
